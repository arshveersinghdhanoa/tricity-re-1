{
  "name": "tricity-re",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @tricity/web dev",
    "build": "pnpm --filter @tricity/core build && pnpm --filter @tricity/pipeline build && pnpm --filter @tricity/web build",
    "test": "pnpm --filter @tricity/core build && pnpm --filter @tricity/pipeline build && pnpm --filter @tricity/core test && pnpm --filter @tricity/pipeline test && pnpm --filter @tricity/web test",
    "lint": "pnpm --filter @tricity/web lint",
    "pipeline:inspect": "pnpm --filter @tricity/pipeline inspect",
    "pipeline:dry-run": "pnpm --filter @tricity/pipeline dry-run",
    "pipeline:scrape": "pnpm --filter @tricity/pipeline scrape",
    "pipeline:promote": "pnpm --filter @tricity/pipeline promote",
    "pipeline:import-prices": "pnpm --filter @tricity/pipeline import-prices",
    "pipeline:stage-prices": "pnpm --filter @tricity/pipeline stage-prices",
    "pipeline:seed-demo-prices": "pnpm --filter @tricity/pipeline seed-demo-prices",
    "demo": "node scripts/run-demo.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
